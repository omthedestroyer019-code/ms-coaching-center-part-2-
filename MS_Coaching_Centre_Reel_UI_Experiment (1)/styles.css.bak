/* Privacy Policy + Terms consent on login */
.legal-consent-box{margin-top:14px;background:rgba(2,6,23,.38);border:1px solid rgba(148,163,184,.22);border-radius:14px;padding:12px}
.legal-check{display:flex!important;align-items:flex-start;gap:10px;margin:0!important;font-weight:700!important;line-height:1.45;color:#e2e8f0}
.legal-check input{width:18px!important;height:18px!important;margin:3px 0 0;flex:0 0 auto;accent-color:#f59e0b;box-shadow:none!important}
.legal-link{display:inline;background:transparent;color:#fde68a;text-decoration:underline;text-underline-offset:3px;padding:0;border:0;font-weight:900;cursor:pointer}
.legal-note{margin:8px 0 0;color:#cbd5e1;font-size:12px}
.primary-btn:disabled{opacity:.55;cursor:not-allowed;filter:grayscale(.25);box-shadow:none!important}
.legal-modal{position:fixed;inset:0;z-index:10000;background:rgba(2,6,23,.76);display:none;align-items:center;justify-content:center;padding:18px;backdrop-filter:blur(10px)}
.legal-modal.show{display:flex}
.legal-modal-card{width:min(680px,100%);max-height:86dvh;overflow:hidden;background:#ffffff;color:#0f172a;border-radius:22px;border:1px solid rgba(255,255,255,.18);box-shadow:0 28px 90px rgba(0,0,0,.45);display:flex;flex-direction:column}
.legal-modal-head{display:flex;align-items:center;justify-content:space-between;gap:12px;padding:16px 18px;background:linear-gradient(135deg,#0f172a,#1e3a8a);color:white}
.legal-modal-head h2{margin:0;font-size:20px}
.legal-close{width:38px;height:38px;border-radius:999px;background:rgba(255,255,255,.14);color:white;font-size:28px;line-height:1;display:grid;place-items:center}
.legal-modal-body{padding:18px;overflow:auto;line-height:1.55}
.legal-modal-body p{margin:0 0 12px;color:#334155}
.legal-modal-body h3{margin:18px 0 8px;color:#0f172a;font-size:16px}
@media (max-width:420px){.legal-modal{padding:10px}.legal-modal-card{max-height:90dvh;border-radius:18px}.legal-modal-body{padding:14px}.legal-check{font-size:13px}}

/* =========================================================
   PHONE LAYOUT FIX: keep orbit buttons visible on real phones
   - fixes overlapping dashboard quick-action buttons
   - fixes More page buttons clipping outside screen
   - avoids calc(var()) transforms that failed on some Android browsers
   ========================================================= */
.quick-orbit-card{
  min-height:360px !important;
  overflow:hidden !important;
}
.quick-orbit-scene{
  min-height:360px !important;
  overflow:hidden !important;
}
.quick-orbit-actions button{
  left:50% !important;
  top:50% !important;
  min-width:104px !important;
  max-width:118px !important;
  min-height:44px !important;
  font-size:12px !important;
  line-height:1.15 !important;
  white-space:normal !important;
  z-index:7 !important;
}
.quick-orbit-center{z-index:5 !important;}
@keyframes quickOrbit1{
  from{transform:translate(-50%,-50%) rotate(0deg) translateY(-116px) rotate(0deg)}
  to{transform:translate(-50%,-50%) rotate(360deg) translateY(-116px) rotate(-360deg)}
}
@keyframes quickOrbit2{
  from{transform:translate(-50%,-50%) rotate(90deg) translateY(-116px) rotate(-90deg)}
  to{transform:translate(-50%,-50%) rotate(450deg) translateY(-116px) rotate(-450deg)}
}
@keyframes quickOrbit3{
  from{transform:translate(-50%,-50%) rotate(180deg) translateY(-116px) rotate(-180deg)}
  to{transform:translate(-50%,-50%) rotate(540deg) translateY(-116px) rotate(-540deg)}
}
@keyframes quickOrbit4{
  from{transform:translate(-50%,-50%) rotate(270deg) translateY(-116px) rotate(-270deg)}
  to{transform:translate(-50%,-50%) rotate(630deg) translateY(-116px) rotate(-630deg)}
}
@keyframes quickOrbit5{
  from{transform:translate(-50%,-50%) rotate(315deg) translateY(-116px) rotate(-315deg)}
  to{transform:translate(-50%,-50%) rotate(675deg) translateY(-116px) rotate(-675deg)}
}

.more-orbit-card{
  min-height:470px !important;
  overflow:hidden !important;
}
.more-orbit-scene{
  min-height:470px !important;
  overflow:hidden !important;
}
.more-orbit-scene::before{width:292px !important;height:292px !important;}
.more-orbit-scene::after{width:205px !important;height:205px !important;}
.more-ring-a{width:250px !important;height:250px !important;}
.more-ring-b{width:320px !important;height:320px !important;}
.more-orbit-logo{
  width:104px !important;
  height:104px !important;
}
.more-orbit-logo img{width:58px !important;height:58px !important;}
.more-orbit-item{
  left:50% !important;
  top:50% !important;
  width:92px !important;
  min-height:48px !important;
  border-radius:15px !important;
  padding:6px 6px !important;
  z-index:7 !important;
}
.more-orbit-item span{font-size:19px !important;}
.more-orbit-item strong{font-size:9.5px !important;line-height:1.08 !important;}
@keyframes moreOrbit1{
  from{transform:translate(-50%,-50%) rotate(0deg) translateY(-116px) rotate(0deg)}
  to{transform:translate(-50%,-50%) rotate(360deg) translateY(-116px) rotate(-360deg)}
}
@keyframes moreOrbit2{
  from{transform:translate(-50%,-50%) rotate(51.4deg) translateY(-116px) rotate(-51.4deg)}
  to{transform:translate(-50%,-50%) rotate(411.4deg) translateY(-116px) rotate(-411.4deg)}
}
@keyframes moreOrbit3{
  from{transform:translate(-50%,-50%) rotate(102.8deg) translateY(-116px) rotate(-102.8deg)}
  to{transform:translate(-50%,-50%) rotate(462.8deg) translateY(-116px) rotate(-462.8deg)}
}
@keyframes moreOrbit4{
  from{transform:translate(-50%,-50%) rotate(154.2deg) translateY(-116px) rotate(-154.2deg)}
  to{transform:translate(-50%,-50%) rotate(514.2deg) translateY(-116px) rotate(-514.2deg)}
}
@keyframes moreOrbit5{
  from{transform:translate(-50%,-50%) rotate(205.6deg) translateY(-116px) rotate(-205.6deg)}
  to{transform:translate(-50%,-50%) rotate(565.6deg) translateY(-116px) rotate(-565.6deg)}
}
@keyframes moreOrbit6{
  from{transform:translate(-50%,-50%) rotate(257deg) translateY(-116px) rotate(-257deg)}
  to{transform:translate(-50%,-50%) rotate(617deg) translateY(-116px) rotate(-617deg)}
}
@keyframes moreOrbit7{
  from{transform:translate(-50%,-50%) rotate(308.4deg) translateY(-116px) rotate(-308.4deg)}
  to{transform:translate(-50%,-50%) rotate(668.4deg) translateY(-116px) rotate(-668.4deg)}
}

@media (max-width:420px){
  .content{padding-left:12px !important;padding-right:12px !important;}
  .quick-orbit-card{min-height:330px !important;}
  .quick-orbit-scene{min-height:330px !important;}
  .quick-orbit-scene::before{width:218px !important;height:218px !important;}
  .quick-orbit-scene::after{width:142px !important;height:142px !important;}
  .quick-orbit-ring{width:248px !important;height:248px !important;}
  .quick-orbit-center{width:96px !important;height:96px !important;}
  .quick-orbit-center strong{font-size:17px !important;}
  .quick-orbit-center span{font-size:11px !important;}
  .quick-orbit-actions button{min-width:88px !important;max-width:98px !important;min-height:40px !important;font-size:11px !important;padding:6px 7px !important;}
  .more-orbit-card{min-height:440px !important;}
  .more-orbit-scene{min-height:440px !important;}
  .more-orbit-item{width:86px !important;min-height:46px !important;}
  .more-orbit-item strong{font-size:9px !important;}
}

/* =========================================================
   HARD MOBILE ORBIT FIX v2
   Problem on Android: when animation/reduced-motion fails, orbit
   items stack at center. This fixes by giving every button a real
   visible static circular position first, then only subtle bobbing.
   ========================================================= */
@media (max-width: 700px) {
  .quick-orbit-card,
  .quick-orbit-scene {
    min-height: 340px !important;
    height: 340px !important;
    overflow: hidden !important;
  }
  .quick-orbit-ring { width: 248px !important; height: 248px !important; }
  .quick-orbit-scene::before { width: 220px !important; height: 220px !important; }
  .quick-orbit-scene::after { width: 142px !important; height: 142px !important; }
  .quick-orbit-center {
    width: 92px !important;
    height: 92px !important;
    z-index: 4 !important;
    pointer-events: none !important;
  }
  .quick-orbit-center span { font-size: 10px !important; line-height: 1 !important; }
  .quick-orbit-center strong { font-size: 16px !important; line-height: 1 !important; }
  .quick-orbit-actions { z-index: 8 !important; }
  .quick-orbit-actions button {
    position: absolute !important;
    width: 94px !important;
    min-width: 94px !important;
    max-width: 94px !important;
    min-height: 40px !important;
    padding: 6px 6px !important;
    font-size: 10.5px !important;
    line-height: 1.05 !important;
    white-space: normal !important;
    z-index: 9 !important;
    transform: translate(-50%, -50%) !important;
    animation: mobileButtonFloat 3s ease-in-out infinite !important;
  }
  .quick-orbit-actions button:nth-child(1) { left: 50% !important; top: 14% !important; animation-delay: 0s !important; }
  .quick-orbit-actions button:nth-child(2) { left: 82% !important; top: 50% !important; animation-delay: .3s !important; }
  .quick-orbit-actions button:nth-child(3) { left: 50% !important; top: 86% !important; animation-delay: .6s !important; }
  .quick-orbit-actions button:nth-child(4) { left: 18% !important; top: 50% !important; animation-delay: .9s !important; }
  .quick-orbit-actions button:nth-child(5) { left: 78% !important; top: 24% !important; animation-delay: 1.2s !important; }

  .more-orbit-card,
  .more-orbit-scene {
    min-height: 465px !important;
    height: 465px !important;
    overflow: hidden !important;
  }
  .more-orbit-scene::before { width: 300px !important; height: 300px !important; }
  .more-orbit-scene::after { width: 205px !important; height: 205px !important; }
  .more-ring-a { width: 252px !important; height: 252px !important; }
  .more-ring-b { width: 320px !important; height: 320px !important; }
  .more-orbit-logo {
    width: 98px !important;
    height: 98px !important;
    left: 50% !important;
    top: 50% !important;
    transform: translate(-50%, -50%) !important;
    z-index: 5 !important;
  }
  .more-orbit-logo img { width: 55px !important; height: 55px !important; }
  .more-orbit-logo span { font-size: 12px !important; }
  .more-orbit-item {
    position: absolute !important;
    width: 86px !important;
    min-width: 86px !important;
    max-width: 86px !important;
    min-height: 46px !important;
    padding: 5px 5px !important;
    border-radius: 14px !important;
    font-size: 9px !important;
    z-index: 9 !important;
    transform: translate(-50%, -50%) !important;
    animation: mobileButtonFloat 3.4s ease-in-out infinite !important;
  }
  .more-orbit-item span { font-size: 18px !important; }
  .more-orbit-item strong { font-size: 8.5px !important; line-height: 1.05 !important; }
  .more-pos-1 { left: 50% !important; top: 10% !important; animation-delay: 0s !important; }
  .more-pos-2 { left: 82% !important; top: 28% !important; animation-delay: .2s !important; }
  .more-pos-3 { left: 86% !important; top: 52% !important; animation-delay: .4s !important; }
  .more-pos-4 { left: 70% !important; top: 80% !important; animation-delay: .6s !important; }
  .more-pos-5 { left: 30% !important; top: 80% !important; animation-delay: .8s !important; }
  .more-pos-6 { left: 14% !important; top: 52% !important; animation-delay: 1s !important; }
  .more-pos-7 { left: 18% !important; top: 28% !important; animation-delay: 1.2s !important; }
}

@keyframes mobileButtonFloat {
  0%, 100% { margin-top: 0; }
  50% { margin-top: -6px; }
}

/* Reduced motion must still keep the static button positions visible. */
@media (max-width: 700px) and (prefers-reduced-motion: reduce) {
  .quick-orbit-actions button,
  .more-orbit-item {
    animation: none !important;
    transform: translate(-50%, -50%) !important;
  }
}

@media (max-width: 370px) {
  .quick-orbit-actions button { width: 86px !important; min-width: 86px !important; max-width: 86px !important; font-size: 9.7px !important; }
  .quick-orbit-actions button:nth-child(2) { left: 83% !important; }
  .quick-orbit-actions button:nth-child(4) { left: 17% !important; }
  .more-orbit-item { width: 80px !important; min-width: 80px !important; max-width: 80px !important; }
  .more-pos-3 { left: 87% !important; }
  .more-pos-6 { left: 13% !important; }
}


/* =========================================================
   JS REAL ORBIT PATCH v3 - works on phones
   The JS sets left/top continuously. These rules stop old CSS
   keyframes from fighting it while keeping glow/pulse movement.
   ========================================================= */
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button,
.more-orbit-scene.js-orbit-enabled .more-orbit-item{
  transform:translate(-50%,-50%) !important;
  transition:none !important;
  will-change:left,top,filter,box-shadow !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{
  animation:orbitGlowPulse 2.8s ease-in-out infinite !important;
}
.more-orbit-scene.js-orbit-enabled .more-orbit-item{
  animation:orbitGlowPulse 3.1s ease-in-out infinite !important;
}
@keyframes orbitGlowPulse{
  0%,100%{filter:brightness(1);box-shadow:0 14px 32px rgba(0,0,0,.25),0 0 20px rgba(37,99,235,.13)}
  50%{filter:brightness(1.08);box-shadow:0 18px 40px rgba(0,0,0,.30),0 0 30px rgba(250,204,21,.20)}
}
@media (max-width:700px){
  .quick-orbit-card,.quick-orbit-scene{height:350px!important;min-height:350px!important;}
  .more-orbit-card,.more-orbit-scene{height:475px!important;min-height:475px!important;}
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{
    width:92px!important;min-width:92px!important;max-width:92px!important;
    min-height:40px!important;font-size:10.5px!important;line-height:1.08!important;
    white-space:normal!important;padding:6px!important;
  }
  .more-orbit-scene.js-orbit-enabled .more-orbit-item{
    width:84px!important;min-width:84px!important;max-width:84px!important;
    min-height:46px!important;padding:5px!important;
  }
}
@media (max-width:370px){
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{width:84px!important;min-width:84px!important;max-width:84px!important;font-size:9.5px!important;}
  .more-orbit-scene.js-orbit-enabled .more-orbit-item{width:78px!important;min-width:78px!important;max-width:78px!important;}
}

/* =========================================================
   FINAL HARD FIX: JS-controlled orbit only, no CSS transform conflict
   - Android Chrome/WebView was overlapping because older CSS keyframes with
     !important were still fighting the JavaScript positions.
   - These rules kill transform animations ONLY inside active JS orbit scenes.
   - JavaScript now owns left/top movement, so buttons stay separated.
   ========================================================= */
.js-orbit-enabled .quick-orbit-actions button,
.js-orbit-enabled .more-orbit-item{
  animation:none !important;
  transition:none !important;
  left:50%;
  top:50%;
  transform:translate(-50%,-50%);
  will-change:left, top, filter;
}
.js-orbit-enabled .quick-orbit-actions button{
  white-space:normal !important;
  min-width:92px !important;
  max-width:116px !important;
  min-height:42px !important;
  padding:7px 8px !important;
  font-size:12px !important;
  line-height:1.1 !important;
}
.js-orbit-enabled .more-orbit-item{
  width:86px !important;
  min-height:46px !important;
  padding:5px !important;
}
.js-orbit-enabled .more-orbit-item strong{
  font-size:9px !important;
  line-height:1.05 !important;
}
.quick-orbit-scene.js-orbit-enabled{
  min-height:370px !important;
}
.more-orbit-scene.js-orbit-enabled{
  min-height:540px !important;
}
@media (max-width:420px){
  .quick-orbit-scene.js-orbit-enabled{min-height:360px !important;}
  .more-orbit-scene.js-orbit-enabled{min-height:520px !important;}
  .js-orbit-enabled .quick-orbit-actions button{min-width:84px !important;max-width:104px !important;font-size:11px !important;}
  .js-orbit-enabled .more-orbit-item{width:82px !important;min-height:44px !important;}
  .js-orbit-enabled .more-orbit-item span{font-size:18px !important;}
  .js-orbit-enabled .more-orbit-item strong{font-size:8.8px !important;}
}

/* =========================================================
   FINAL PHONE ORBIT PATCH v4
   Real fix: JS sets inline left/top/transform with !important.
   These CSS rules only size the orbit scenes and buttons. No moving CSS.
   ========================================================= */
.quick-orbit-scene.js-orbit-enabled,
.more-orbit-scene.js-orbit-enabled{
  position:relative !important;
  overflow:hidden !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions,
.more-orbit-scene.js-orbit-enabled{
  position:relative !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button,
.more-orbit-scene.js-orbit-enabled .more-orbit-item{
  position:absolute !important;
  animation:none !important;
  transition:none !important;
  transform:translate(-50%,-50%) !important;
  will-change:left,top !important;
  box-sizing:border-box !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{
  width:92px !important;
  min-width:92px !important;
  max-width:92px !important;
  min-height:40px !important;
  font-size:10.6px !important;
  line-height:1.05 !important;
  padding:6px !important;
  white-space:normal !important;
}
.more-orbit-scene.js-orbit-enabled .more-orbit-item{
  width:78px !important;
  min-width:78px !important;
  max-width:78px !important;
  min-height:43px !important;
  padding:5px 4px !important;
}
.more-orbit-scene.js-orbit-enabled .more-orbit-item span{font-size:17px !important;}
.more-orbit-scene.js-orbit-enabled .more-orbit-item strong{font-size:8.2px !important;line-height:1.02 !important;}
@media (max-width:700px){
  .quick-orbit-card,.quick-orbit-scene.js-orbit-enabled{height:360px !important;min-height:360px !important;}
  .more-orbit-card,.more-orbit-scene.js-orbit-enabled{height:535px !important;min-height:535px !important;}
  .more-orbit-logo{width:94px !important;height:94px !important;}
  .more-orbit-logo img{width:52px !important;height:52px !important;}
}
@media (max-width:370px){
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{width:84px !important;min-width:84px !important;max-width:84px !important;font-size:9.7px !important;}
  .more-orbit-scene.js-orbit-enabled .more-orbit-item{width:72px !important;min-width:72px !important;max-width:72px !important;}
  .more-orbit-scene.js-orbit-enabled .more-orbit-item strong{font-size:7.8px !important;}
}

/* =========================================================
   HOME QUICK ACTION ORBIT FIX v5
   More page orbit is kept unchanged. This fixes only Home dashboard
   Quick Actions by forcing a centered, capped transform orbit so buttons
   cannot fly outside or overlap on phone/desktop wrappers.
   ========================================================= */
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions{
  position:absolute !important;
  inset:0 !important;
  z-index:8 !important;
  pointer-events:none !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{
  position:absolute !important;
  left:50% !important;
  top:50% !important;
  width:112px !important;
  min-width:112px !important;
  max-width:112px !important;
  min-height:44px !important;
  padding:7px 8px !important;
  border-radius:999px !important;
  white-space:normal !important;
  font-size:12px !important;
  line-height:1.08 !important;
  text-align:center !important;
  pointer-events:auto !important;
  animation:none !important;
  transition:none !important;
  will-change:transform !important;
  box-sizing:border-box !important;
  z-index:10 !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-center{
  width:108px !important;
  height:108px !important;
  z-index:6 !important;
  pointer-events:none !important;
}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-center span{font-size:11px !important;}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-center strong{font-size:18px !important;}
.quick-orbit-scene.js-orbit-enabled .quick-orbit-ring{width:286px !important;height:286px !important;}
.quick-orbit-scene.js-orbit-enabled::before{width:246px !important;height:246px !important;}
.quick-orbit-scene.js-orbit-enabled::after{width:158px !important;height:158px !important;}
@media (max-width:700px){
  .quick-orbit-card,
  .quick-orbit-scene.js-orbit-enabled{
    height:350px !important;
    min-height:350px !important;
    overflow:hidden !important;
  }
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{
    width:92px !important;
    min-width:92px !important;
    max-width:92px !important;
    min-height:40px !important;
    font-size:10.4px !important;
    padding:6px !important;
  }
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-center{
    width:94px !important;
    height:94px !important;
  }
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-center span{font-size:10px !important;}
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-center strong{font-size:16px !important;}
}
@media (max-width:370px){
  .quick-orbit-scene.js-orbit-enabled .quick-orbit-actions button{
    width:84px !important;
    min-width:84px !important;
    max-width:84px !important;
    font-size:9.5px !important;
  }
}


/* =========================================================
   SAVED WORKING ORBIT + SMOOTH SCROLL REVEAL + LIQUID LOGIN REVEAL
   - More page orbit stays unchanged
   - Home Quick Actions orbit stays unchanged
   - Parallax removed to prevent scroll jank on phones
   - Adds lightweight reveal-on-scroll motion instead
   ========================================================= */
body{
  background:
    radial-gradient(circle at 50% 0%, rgba(37,99,235,.18), transparent 34%),
    linear-gradient(90deg,rgba(148,163,184,.055) 1px,transparent 1px),
    linear-gradient(180deg,rgba(148,163,184,.045) 1px,transparent 1px),
    #020617 !important;
  background-size:auto,38px 38px,38px 38px,auto;
  background-attachment:scroll;
}
.app-shell{
  position:relative;
  overflow:hidden;
  isolation:isolate;
}
.app-shell::after{
  content:"";
  position:fixed;
  left:50%;
  top:10%;
  width:min(720px,92vw);
  height:min(720px,92vw);
  transform:translate3d(-50%,0,0);
  border-radius:50%;
  background:
    radial-gradient(circle, rgba(37,99,235,.13) 0 12%, transparent 13% 100%),
    repeating-radial-gradient(circle, rgba(250,204,21,.08) 0 1px, transparent 2px 70px),
    repeating-radial-gradient(circle, rgba(148,163,184,.07) 0 1px, transparent 2px 104px);
  opacity:.38;
  pointer-events:none;
  z-index:0;
  animation:ambientDrift 18s ease-in-out infinite alternate;
}
@keyframes ambientDrift{
  from{transform:translate3d(-51%,-6px,0) rotate(-2deg) scale(.985)}
  to{transform:translate3d(-49%,8px,0) rotate(2deg) scale(1.015)}
}
.scroll-reveal{
  opacity:0;
  transform:translate3d(0,18px,0) scale(.988);
  filter:saturate(.92);
  transition:
    opacity .58s cubic-bezier(.2,.9,.2,1),
    transform .58s cubic-bezier(.2,.9,.2,1),
    filter .58s ease;
  transition-delay:var(--reveal-delay,0ms);
  will-change:opacity,transform;
}
.scroll-reveal.revealed{
  opacity:1;
  transform:translate3d(0,0,0) scale(1);
  filter:saturate(1);
}
.page-enter{animation:pageFadeSmooth .32s cubic-bezier(.2,.9,.2,1) both}
@keyframes pageFadeSmooth{from{opacity:0;transform:translate3d(0,8px,0)}to{opacity:1;transform:translate3d(0,0,0)}}
.card,.item,.stat-card,.search-card,.primary-btn,.secondary-btn,.accent-btn,.danger-btn,.ghost-btn,.link-btn,.bottom-nav button{
  transition:transform .24s cubic-bezier(.2,.9,.2,1), box-shadow .24s cubic-bezier(.2,.9,.2,1), filter .24s ease, background .24s ease;
}
.card:hover,.item:hover,.stat-card:hover{
  box-shadow:0 18px 48px rgba(0,0,0,.32),0 0 30px rgba(37,99,235,.12),inset 0 1px 0 rgba(255,255,255,.06);
}
.primary-btn:active,.secondary-btn:active,.accent-btn:active,.danger-btn:active,.ghost-btn:active,.link-btn:active,.bottom-nav button:active{transform:scale(.985)}
#loginSubmitBtn{
  position:relative;
  overflow:hidden;
  isolation:isolate;
  transform:translateZ(0);
}
#loginSubmitBtn::after{
  content:"";
  position:absolute;
  inset:-2px;
  background:linear-gradient(90deg,transparent,rgba(255,255,255,.34),transparent);
  transform:translate3d(-120%,0,0);
  transition:transform .55s cubic-bezier(.2,.9,.2,1);
  pointer-events:none;
}
#loginSubmitBtn:not(:disabled):hover::after,
#loginSubmitBtn:not(:disabled):focus-visible::after{transform:translate3d(120%,0,0)}
.login-expand-circle{
  position:fixed;
  left:var(--login-circle-x,50vw);
  top:var(--login-circle-y,50vh);
  width:32px;
  height:32px;
  border-radius:50%;
  transform:translate3d(-50%,-50%,0) scale(.01);
  transform-origin:center;
  z-index:10000;
  pointer-events:none;
  background:
    radial-gradient(circle at 40% 35%, rgba(254,243,199,.98), rgba(245,158,11,.98) 18%, rgba(37,99,235,.99) 50%, rgba(2,6,23,1) 100%);
  box-shadow:0 0 50px rgba(250,204,21,.36),0 0 90px rgba(37,99,235,.30);
  opacity:1;
  will-change:transform,opacity;
  backface-visibility:hidden;
  contain:layout paint style;
}
.login-expand-circle.active{
  transform:translate3d(-50%,-50%,0) scale(var(--login-circle-scale,120));
  transition:transform 1.08s cubic-bezier(.16,1,.3,1);
}
.login-expand-circle.fade-out{
  opacity:0;
  transform:translate3d(-50%,-50%,0) scale(calc(var(--login-circle-scale,120) * 1.01));
  transition:opacity .34s ease-out, transform .34s cubic-bezier(.22,1,.36,1);
}
.login-reveal-hidden{opacity:0;transform:translate3d(0,6px,0) scale(.996)}
.login-reveal-ready{animation:loginDashboardReveal .5s cubic-bezier(.2,.9,.2,1) both}
@keyframes loginDashboardReveal{
  from{opacity:0;transform:translate3d(0,8px,0) scale(.996)}
  to{opacity:1;transform:translate3d(0,0,0) scale(1)}
}
body.login-transitioning .app-shell::after,
body.login-transitioning .topbar,
body.login-transitioning .content > *{
  transition:none!important;
  animation:none!important;
}
body.login-transitioning .scroll-reveal{opacity:1!important;transform:none!important;transition:none!important;filter:none!important;}
@media (max-width:520px){
  .app-shell::after{width:560px;height:560px;top:12%;animation-duration:22s;}
  .scroll-reveal{transform:translate3d(0,12px,0) scale(.994);transition-duration:.46s;}
}
@media (prefers-reduced-motion:reduce){
  .login-expand-circle,.login-expand-circle.active,.login-expand-circle.fade-out,.login-reveal-ready,.scroll-reveal,.app-shell::after{animation:none!important;transition:none!important;}
  .scroll-reveal{opacity:1!important;transform:none!important;filter:none!important;}
}
